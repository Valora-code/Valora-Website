# Clerk — publishable key for the Clerk application that has Waitlist enabled (Dashboard → Waitlist).
# Required for the homepage early-access section to use Clerk’s `<Waitlist />`. Omit locally to use the mailto fallback there instead.
# Dashboard waitlist URL must match the homepage (e.g. http://localhost:8080/), not /waitlist, or the form renders empty.
VITE_CLERK_PUBLISHABLE_KEY=

# Optional — base URL of the Valora web app (no trailing slash). Used for Sign up / Sign in links.
# Default: https://app.valora-tech.com
# VITE_VALORA_APP_ORIGIN=
