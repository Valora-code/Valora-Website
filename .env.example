# Clerk — publishable key for the Clerk application that has Waitlist enabled (Dashboard → Waitlist).
# Required for `/waitlist` to use Clerk’s `<Waitlist />`. Omit locally to use the mailto fallback instead.
VITE_CLERK_PUBLISHABLE_KEY=

# Optional — base URL of the Valora web app (no trailing slash). Used for Sign up / Sign in links.
# Default: https://app.valora-tech.com
# VITE_VALORA_APP_ORIGIN=
